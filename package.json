{
  "name": "application_pipeline",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "esbuild app/javascript/application.ts --bundle --sourcemap --outdir=app/assets/builds --public-path=/assets",
    "build:watch": "esbuild app/javascript/application.ts --bundle --sourcemap --outdir=app/assets/builds --public-path=/assets --watch",
    "lint": "eslint 'app/javascript/**/*.ts'",
    "format": "prettier --write 'app/javascript/**/*.ts'",
    "format:check": "prettier --check 'app/javascript/**/*.ts'",
    "prepare": "husky"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.12",
    "@stimulus-components/dialog": "^1.0.1",
    "chart.js": "^4.5.1",
    "tom-select": "^2.6.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
