<%= render UI::PageHeaderComponent.new(title: "Chats") %>

<% if @pagy.count > 0 %>
  <p class="mb-2 text-xs text-gray-500"><%= @pagy.count %> total</p>
<% end %>

<%= render UI::TableComponent.new(collection: @chats, empty_message: "No chats found.", pagy: @pagy) do |table| %>
  <% table.with_columns([
    { key: "id",         label: "ID",      variant: :mono,   cell: ->(chat) { "##{chat.id}" } },
    { key: "model",      label: "Model",   variant: :subtle, cell: ->(chat) { chat.model&.name || "—" } },
    { key: "created_at", label: "Created", variant: :subtle, cell: ->(chat) { chat.created_at.strftime("%b %-d, %Y %H:%M") } },
    { key: "updated_at", label: "Updated", variant: :subtle, cell: ->(chat) { chat.updated_at.strftime("%b %-d, %Y %H:%M") } }
  ]) %>
  <% table.with_action_column(
    actions: ->(chat) {
      [
        { label: "View",   url: chat_path(chat),   variant: :primary },
        { label: "Delete", url: chat_path(chat),   method: :delete,  variant: :danger, confirm: "Delete chat ##{chat.id}?" }
      ]
    }
  ) %>
<% end %>
