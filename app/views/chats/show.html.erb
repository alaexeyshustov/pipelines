<%= render UI::PageHeaderComponent.new(
      title: "Chat ##{@chat.id}",
      parent: { label: "Chats", url: chats_path }
    ) do |header| %>
  <% header.with_action(type: :delete, label: "Delete", url: chat_path(@chat), confirm: "Delete chat ##{@chat.id}?") %>
<% end %>

<%= render Chats::DetailCardComponent.new(chat: @chat) %>

<h2 class="text-lg font-semibold text-gray-900 mb-4">Messages</h2>

<% if @chat.messages.empty? %>
  <p class="text-gray-400 text-sm">No messages.</p>
<% else %>
  <div class="space-y-4">
    <%= render Chats::MessageComponent.with_collection(@chat.messages.order(:created_at)) %>
  </div>
<% end %>
