<%= form_with(model: [:settings, email_connector], class: "space-y-6") do |f| %>
  <% if email_connector.errors.any? %>
    <div class="bg-red-50 text-red-700 p-4 rounded-lg">
      <h2 class="font-bold"><%= pluralize(email_connector.errors.count, "error") %> prohibited this connector from being saved:</h2>
      <ul class="list-disc list-inside">
        <% email_connector.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
  </div>

  <div>
    <%= f.label :provider, class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :provider, [['Gmail', 'gmail'], ['Yahoo', 'yahoo']], {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", 
        data: { controller: "connector-form", action: "change->connector-form#toggleFields" } %>
  </div>

  <div class="space-y-4 bg-gray-50 p-4 rounded-lg">
    <h3 class="text-sm font-medium text-gray-900">Configuration</h3>
    
    <%= f.fields_for :configuration do |c| %>
      <div id="gmail-fields" class="<%= 'hidden' unless email_connector.provider == 'gmail' %>">
        <div class="mb-4">
          <%= c.label :credentials_path, "Credentials JSON Path", class: "block text-xs font-medium text-gray-500" %>
          <%= c.text_field :credentials_path, value: email_connector.configuration&.dig(:credentials_path), class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
        </div>
        <div class="mb-4">
          <%= c.label :token_path, "Token YAML Path", class: "block text-xs font-medium text-gray-500" %>
          <%= c.text_field :token_path, value: email_connector.configuration&.dig(:token_path), class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
        </div>
        <% if email_connector.persisted? %>
          <%= link_to "Connect Gmail", setup_settings_email_connector_path(email_connector),
              class: "inline-block bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
        <% end %>
      </div>

      <div id="yahoo-fields" class="<%= 'hidden' unless email_connector.provider == 'yahoo' %>">
        <div class="mb-4">
          <%= c.label :username, "Yahoo Email", class: "block text-xs font-medium text-gray-500" %>
          <%= c.text_field :username, value: email_connector.configuration&.dig(:username), class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
        </div>
        <div class="mb-4">
          <%= c.label :password, "App Password", class: "block text-xs font-medium text-gray-500" %>
          <%= f.password_field "configuration[password]", value: email_connector.configuration&.dig(:password), class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= c.label :host, "IMAP Host", class: "block text-xs font-medium text-gray-500" %>
            <%= c.text_field :host, value: email_connector.configuration&.dig(:host) || "imap.mail.yahoo.com", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>
          <div>
            <%= c.label :port, "Port", class: "block text-xs font-medium text-gray-500" %>
            <%= c.number_field :port, value: email_connector.configuration&.dig(:port) || 993, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="flex items-center">
    <%= f.check_box :enabled, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
    <%= f.label :enabled, class: "ml-2 block text-sm text-gray-900" %>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", settings_email_connectors_path, class: "bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors" %>
    <%= f.submit class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
  </div>
<% end %>

<script>
  // Simple Stimulus-like behavior without needing a separate file for now
  document.addEventListener("change", function(e) {
    if (e.target.id === "email_connector_provider") {
      const provider = e.target.value;
      const gmailFields = document.getElementById("gmail-fields");
      const yahooFields = document.getElementById("yahoo-fields");
      
      if (provider === "gmail") {
        gmailFields.classList.remove("hidden");
        yahooFields.classList.add("hidden");
      } else if (provider === "yahoo") {
        gmailFields.classList.add("hidden");
        yahooFields.classList.remove("hidden");
      } else {
        gmailFields.classList.add("hidden");
        yahooFields.classList.add("hidden");
      }
    }
  });
</script>
