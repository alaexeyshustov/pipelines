<%= form_with url: evaluation_metrics_path, method: :post, class: "space-y-4" do |f| %>
  <% if metric.errors.any? %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-3 text-sm text-red-700">
      <ul class="space-y-1">
        <% metric.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.hidden_field :agent_name, value: metric.agent_name %>

  <div>
    <label class="block text-xs font-medium text-gray-600 mb-1">Name</label>
    <%= f.text_field :name, class: "w-full rounded border border-gray-300 px-2 py-1.5 text-sm" %>
  </div>
  <div>
    <label class="block text-xs font-medium text-gray-600 mb-1">Description</label>
    <%= f.text_area :description, rows: 2, class: "w-full rounded border border-gray-300 px-2 py-1.5 text-sm" %>
  </div>
  <div>
    <label class="block text-xs font-medium text-gray-600 mb-1">Weight</label>
    <%= f.number_field :weight, step: 0.1, min: 0, class: "w-32 rounded border border-gray-300 px-2 py-1.5 text-sm" %>
  </div>
  <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700">Save metric</button>
<% end %>
