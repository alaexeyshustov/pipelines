<% if suggestions.any? %>
  <div class="space-y-3 mt-4">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">AI Suggestions</p>
    <% suggestions.each do |suggestion| %>
      <div class="border border-indigo-200 rounded-lg p-3 bg-indigo-50">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold text-gray-900"><%= suggestion[:name] %></p>
            <p class="text-xs text-gray-600 mt-0.5"><%= suggestion[:description] %></p>
          </div>
          <span class="text-xs text-gray-500 shrink-0">weight: <%= suggestion[:weight] %></span>
        </div>
        <%= form_with url: evaluation_metrics_path, method: :post, class: "mt-2", data: { turbo: true } do |f| %>
          <%= f.hidden_field :evaluation_metric, name: "evaluation_metric[agent_name]", value: agent_name %>
          <%= f.hidden_field :evaluation_metric, name: "evaluation_metric[name]", value: suggestion[:name] %>
          <%= f.hidden_field :evaluation_metric, name: "evaluation_metric[description]", value: suggestion[:description] %>
          <%= f.hidden_field :evaluation_metric, name: "evaluation_metric[weight]", value: suggestion[:weight] %>
          <button type="submit" class="text-xs font-medium text-indigo-600 hover:text-indigo-800">
            + Add this metric
          </button>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="mt-3 text-sm text-gray-400">No suggestions returned.</p>
<% end %>
