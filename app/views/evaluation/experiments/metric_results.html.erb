<%= render UI::PageHeaderComponent.new(
  title: @metric_name,
  parent: { label: @experiment.name, url: evaluation_experiment_path(@experiment) }
) %>

<div class="space-y-4 max-w-3xl">
  <% if @justifications.empty? %>
    <div class="rounded-lg border border-gray-200 bg-white p-6">
      <p class="text-sm text-gray-400">No evaluation results for this metric.</p>
    </div>
  <% else %>
    <% @justifications.each_with_index do |justification, index| %>
      <% eval_result   = justification.evaluation_result %>
      <% runner_result = eval_result.runner_result %>
      <% dataset_record = eval_result.dataset_record %>
      <div class="rounded-lg border border-gray-200 bg-white p-5 space-y-4">
        <div class="flex items-center justify-between">
          <span class="text-xs font-medium text-gray-500 uppercase tracking-wide">Result #<%= index + 1 %></span>
          <% if eval_result.score %>
            <span class="text-sm font-semibold text-gray-900">
              <%= "%.2f" % eval_result.score %> <span class="text-xs font-normal text-gray-400">/ 5</span>
            </span>
          <% end %>
        </div>

        <% if dataset_record.actual_result.present? %>
          <div>
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Expected</p>
            <pre class="text-xs text-gray-700 whitespace-pre-wrap bg-gray-50 rounded p-3 leading-relaxed"><%= dataset_record.actual_result %></pre>
          </div>
        <% end %>

        <% if runner_result&.prediction.present? %>
          <div>
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Agent output</p>
            <pre class="text-xs text-gray-700 whitespace-pre-wrap bg-blue-50 rounded p-3 leading-relaxed"><%= runner_result.prediction %></pre>
          </div>
        <% end %>

        <div>
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Justification</p>
          <p class="text-sm text-gray-700 leading-relaxed"><%= justification.justification %></p>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
