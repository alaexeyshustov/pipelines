<%= render UI::PageHeaderComponent.new(title: "Pipelines", notice: notice, alert: alert) do |header| %>
  <% header.with_action(type: :link, label: "New Pipeline", url: new_orchestration_pipeline_path) %>
<% end %>

<%= render UI::TableComponent.new(collection: @pipelines, empty_message: "No pipelines found.") do |table| %>
  <% table.with_columns([
    { key: "name",        label: "Name",        cell: ->(pipeline) { link_to(pipeline.name, orchestration_pipeline_path(pipeline), class: "hover:text-indigo-600 font-medium text-gray-900") } },
    { key: "description", label: "Description", variant: :muted, cell: ->(pipeline) { pipeline.description || "—" } },
    { key: "step_count",  label: "Steps",       variant: :muted },
    { key: "status",      label: "Status",      component: UI::StatusBadgeComponent, props: ->(pipeline) { { label: pipeline.enabled? ? "Enabled" : "Disabled", variant: pipeline.enabled? ? :success : :neutral } } }
  ]) %>
  <% table.with_action_column(
    actions: ->(pipeline) {
      [
        { label: pipeline.enabled? ? "Disable" : "Enable", url: toggle_orchestration_pipeline_path(pipeline), method: :patch, variant: :neutral },
        { label: "Edit", url: edit_orchestration_pipeline_path(pipeline), variant: :primary },
        { label: "Delete", url: orchestration_pipeline_path(pipeline), method: :delete, variant: :danger, confirm: "Delete pipeline \"#{pipeline.name}\"? This will also delete all steps and step-actions." }
      ]
    }
  ) %>
<% end %>