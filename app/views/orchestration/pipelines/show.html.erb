<%= render UI::PageHeaderComponent.new(
      title: @pipeline.name,
      parent: { label: "Pipelines", url: orchestration_pipelines_path },
      notice: notice,
      alert: alert
    ) do |header| %>
  <% header.with_badge(label: @pipeline.enabled? ? "Enabled" : "Disabled", variant: @pipeline.enabled? ? :success : :neutral) %>

  <% if @pipeline.initial_input_schema.present? %>
    <% header.with_action(type: :dialog,
                          label: "Run now",
                          dialog_title: "Run \"#{@pipeline.name}\"",
                          url: run_orchestration_pipeline_path(@pipeline),
                          method: :post,
                          confirm_label: "Run",
                          variant: :primary,
                          size: :md,
                          body_component: UI::JsonFieldsComponent,
                          body_options: { schema: @pipeline.initial_input_schema, name_prefix: "initial_input" }) %>
  <% else %>
    <% header.with_action(type: :button, label: "Run now",
                          url: run_orchestration_pipeline_path(@pipeline),
                          method: :post, variant: :primary) %>
  <% end %>

  <% header.with_action(type: :button,
                        label: @pipeline.enabled? ? "Disable" : "Enable",
                        url: toggle_orchestration_pipeline_path(@pipeline),
                        method: :patch,
                        variant: @pipeline.enabled? ? :neutral : :success) %>
  <% header.with_action(type: :link, label: "Edit",
                        url: edit_orchestration_pipeline_path(@pipeline),
                        variant: :secondary) %>
  <% header.with_action(type: :dialog,
                        label: "Delete",
                        dialog_title: "Delete pipeline \"#{@pipeline.name}\"? This will also delete all steps and step-actions.",
                        url: orchestration_pipeline_path(@pipeline),
                        method: :delete,
                        confirm_label: "Yes, delete",
                        variant: :danger) %>
  <% header.with_action(type: :link, label: "Run History",
                        url: orchestration_pipeline_pipeline_runs_path(@pipeline),
                        variant: :ghost) %>
<% end %>

<div class="mb-4">
  <%= render UI::DetailCardComponent.new(
    entity: @pipeline,
    attributes: [
      *([{ label: "Description", attribute: :description }] if @pipeline.description.present?),
      *([{ label: "Schedule",    attribute: :cron_expression, type: :mono }] if @pipeline.cron_expression.present?)
    ]
  ) %>
</div>

<% if @latest_run %>
  <div class="mb-4">
    <h3 class="text-sm font-medium text-gray-500 mb-2">Latest Run</h3>
    <%= render UI::DetailCardComponent.new(
          entity: @latest_run,
          attributes: [
            { label: "Status",   attribute: :status, type: :badge,
              variant_map: { "pending" => :neutral, "running" => :info,
                             "completed" => :success, "failed" => :danger } },
            { label: "Started",  attribute: :started_at,  type: :date },
            { label: "Finished", attribute: :finished_at, type: :date },
            { label: "Error",    attribute: :error },
            *([{ label: "Input Parameters", attribute: :initial_input, type: :json }] if @latest_run.initial_input.present?)
          ]
        ) %>
  </div>
<% end %>

<div class="grid grid-cols-1 gap-6">
  <%# Steps section %>
  <turbo-frame id="steps">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900">Steps</h2>
      </div>

      <% if @steps.empty? %>
        <p class="px-6 py-8 text-center text-gray-400 text-sm">No steps yet. Add a step below.</p>
      <% else %>
        <div class="divide-y divide-gray-100">
          <%= render Orchestration::StepComponent.with_collection(@steps, pipeline: @pipeline, actions: @actions) %>
        </div>
      <% end %>

      <%= render Orchestration::NewStepComponent.new(pipeline: @pipeline) %>
    </div>
  </turbo-frame>
</div>
