<%= render UI::PageHeaderComponent.new(title: "Action Library", notice: notice, alert: alert) do |header| %>
  <% header.with_action(type: :link, label: "New Action", url: new_orchestration_action_path) %>
<% end %>

<%= render UI::TableComponent.new(collection: @actions, empty_message: "No actions found.") do |table| %>
  <% table.with_columns([
    { key: "name",           label: "Name" },
    { key: "agent_class",    label: "Agent Class", classes: "px-4 py-3 font-mono text-gray-600 text-xs" },
    { key: "model",          label: "Model",     variant: :muted, cell: ->(action) { action.model || "—" } },
    { key: "pipeline_count", label: "Pipelines", variant: :muted }
  ]) %>
  <% table.with_action_column(
    actions: ->(action) {
      [
        { label: "Edit", url: edit_orchestration_action_path(action), variant: :primary },
        { label: "Delete", url: orchestration_action_path(action), method: :delete, variant: :danger, confirm: "Delete action \"#{action.name}\"?" }
      ]
    }
  ) %>
<% end %>
