<% content_for :title, "Actions" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Action Library</h1>
  <%= link_to "New Action", new_orchestration_action_path, class: "px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors" %>
</div>

<% if notice.present? %>
  <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 text-green-800 rounded-lg text-sm"><%= notice %></div>
<% end %>

<% if alert.present? %>
  <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-800 rounded-lg text-sm"><%= alert %></div>
<% end %>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="px-4 py-3 text-left font-medium text-gray-600">Name</th>
        <th class="px-4 py-3 text-left font-medium text-gray-600">Agent Class</th>
        <th class="px-4 py-3 text-left font-medium text-gray-600">Model</th>
        <th class="px-4 py-3 text-left font-medium text-gray-600">Pipelines</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @actions.empty? %>
        <tr>
          <td colspan="5" class="px-4 py-10 text-center text-gray-400">No actions found.</td>
        </tr>
      <% else %>
        <% @actions.each do |action| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-3 font-medium text-gray-900"><%= action.name %></td>
            <td class="px-4 py-3 font-mono text-gray-600 text-xs"><%= action.agent_class %></td>
            <td class="px-4 py-3 text-gray-500"><%= action.model || "—" %></td>
            <td class="px-4 py-3 text-gray-500"><%= action.pipeline_count %></td>
            <td class="px-4 py-3 text-right flex items-center justify-end gap-3">
              <%= link_to "Edit", edit_orchestration_action_path(action), class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
              <%= button_to "Delete", orchestration_action_path(action), method: :delete,
                    form: { data: { turbo_confirm: "Delete action \"#{action.name}\"?" } },
                    class: "text-red-500 hover:text-red-700 font-medium bg-transparent border-0 cursor-pointer p-0" %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
