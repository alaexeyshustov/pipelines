<%= render UI::PageHeaderComponent.new(
      title: "Run History",
      parent: { label: @pipeline.name, url: orchestration_pipeline_path(@pipeline) }
    ) %>

<% if @pagy.count > 0 %>
  <p class="mb-2 text-xs text-gray-500"><%= @pagy.count %> total</p>
<% end %>

<%= render UI::TableComponent.new(collection: @runs, empty_message: "No runs yet.", pagy: @pagy) do |table| %>
  <% table.with_columns([
    { key: "status",       label: "Status",       style: :compact, badge: Orchestration::RunStatusBadgeComponent },
    { key: "triggered_by", label: "Triggered By", style: :compact, variant: :subtle, cell: ->(run) { run.triggered_by || "—" } },
    { key: "started_at",   label: "Started",      style: :compact, variant: :subtle, cell: ->(run) { run.started_at ? run.started_at.strftime("%Y-%m-%d %H:%M:%S") : "—" } },
    { key: "finished_at",  label: "Finished",     style: :compact, variant: :subtle, cell: ->(run) { run.finished_at ? run.finished_at.strftime("%Y-%m-%d %H:%M:%S") : "—" } },
    { key: "duration",     label: "Duration",     style: :compact, variant: :subtle, cell: ->(run) { run.started_at && run.finished_at ? distance_of_time_in_words(run.started_at, run.finished_at) : "—" } }
  ]) %>
  <% table.with_action_column(
    style: :compact,
    actions: ->(run) {
      [{ label: "Details", url: orchestration_pipeline_pipeline_run_path(@pipeline, run), variant: :primary }]
    }
  ) %>
<% end %>
