<%= render UI::PageHeaderComponent.new(title: "Models") do |header| %>
  <% header.with_action(type: :button, label: "Sync Models", url: sync_models_path, method: :post, variant: :primary) %>
<% end %>

<%= render UI::TableComponent.new(collection: @models, empty_message: "No models found.") do |table| %>
  <% table.with_columns([
    { key: "id",                       label: "ID",             style: :compact },
    { key: "display_name",             label: "Name",           style: :compact },
    { key: "provider",                 label: "Provider",       style: :compact, variant: :subtle },
    { key: "context_window",           label: "Context Window", style: :compact, variant: :subtle },
    { key: "input_price_per_million",  label: "Input $/M",      style: :compact, variant: :subtle, cell: ->(m) { m.input_price_per_million ? "$#{"%.4f" % m.input_price_per_million}" : "—" } },
    { key: "output_price_per_million", label: "Output $/M",     style: :compact, variant: :subtle, cell: ->(m) { m.output_price_per_million ? "$#{"%.4f" % m.output_price_per_million}" : "—" } },
    { key: "modalities",               label: "Modalities",     style: :compact, variant: :subtle, cell: ->(m) { [ *m.modalities.input, *m.modalities.output ].uniq.join(", ") } }
  ]) %>
<% end %>
