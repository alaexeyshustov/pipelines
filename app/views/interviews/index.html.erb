<%= render UI::PageHeaderComponent.new(title: "Interviews", notice: notice, alert: alert) %>

<%= render Interviews::SearchFormComponent.new(
      url: interviews_path,
      query: @query,
      clear_url: interviews_path
    ) %>

<div data-controller="batch">
  <%= render UI::TableComponent.new(
        collection: @interviews,
        selectable: true,
        pagy: @pagy,
        filters: @filters
      ) do |table| %>
    <% table.with_batch_actions([
      { label: "Delete",     url: batch_interviews_path, action: "delete", variant: :danger,     confirm: "Delete selected interviews?" },
      { label: "Merge",      url: batch_interviews_path, action: "merge",  variant: :secondary,  confirm: "Merge selected interviews into one?" },
      { label: "Export CSV", url: batch_interviews_path, action: "export", variant: :success, require_selection: false }
    ]) %>
    <% table.with_batch_action(
         type: :dialog,
         label: "Export to Gist",
         dialog_title: "Export to GitHub Gist",
         url: export_gist_interviews_path,
         action: "export_gist",
         confirm: "Export",
         variant: :secondary
       ) do %>
      <label class="block text-sm text-gray-700 mb-1" for="gist-id-input">Gist ID</label>
      <input type="text" name="gist_id" id="gist-id-input" required
             placeholder="e.g. 6cad326836d38bd3a7ae"
             class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-300 mb-4">
    <% end %>
    <% table.with_columns([
      { key: "company",   label: "Company" },
      { key: "job_title", label: "Job Title" },
      { key: "status",    label: "Status", badge: Interviews::StatusBadgeComponent },
      { key: "applied_at", label: "Applied" }
    ]) %>
    <% table.with_action_column(
      actions: ->(interview) {
        [
          { label: "View", url: interview_path(interview), variant: :neutral },
          { label: "Edit", url: edit_interview_path(interview), variant: :primary },
          { label: "Delete", url: interview_path(interview), method: :delete, variant: :danger, confirm: "Delete this interview record?" }
        ]
      }
    ) %>
  <% end %>
</div>
