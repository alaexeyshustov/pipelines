<%= render UI::PageHeaderComponent.new(
      title: "#{@interview.company} — #{@interview.job_title}",
      parent: { label: "Interviews", url: interviews_path },
      notice: notice
    ) do |header| %>
  <% header.with_action(type: :link,   label: "Edit",   url: edit_interview_path(@interview)) %>
  <% header.with_action(type: :delete, label: "Delete", url: interview_path(@interview), confirm: "Delete this interview record?") %>
<% end %>

<%= render UI::DetailCardComponent.new(
      entity: @interview,
      attributes: [
        { label: "Company",       attribute: :company },
        { label: "Job Title",     attribute: :job_title },
        { label: "Status",        attribute: :status, type: :badge,
          variant_map: { "pending_reply" => :warning, "having_interviews" => :info,
                         "rejected" => :danger, "offer_received" => :success } },
        { label: "Applied",       attribute: :applied_at,           type: :date },
        { label: "Rejected",      attribute: :rejected_at,          type: :date },
        { label: "1st Interview", attribute: :first_interview_at,   type: :date },
        { label: "2nd Interview", attribute: :second_interview_at,  type: :date },
        { label: "3rd Interview", attribute: :third_interview_at,   type: :date },
        { label: "4th Interview", attribute: :fourth_interview_at,  type: :date }
      ]
    ) %>
