<%= form_with model: mail, class: "space-y-6" do |f| %>
  <% if mail.errors.any? %>
    <div class="px-4 py-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-800">
      <p class="font-medium mb-1">Please fix the following errors:</p>
      <ul class="list-disc list-inside space-y-0.5">
        <% mail.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :date, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.date_field :date, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 #{"border-red-400" if mail.errors[:date].any?}" %>
    <% if mail.errors[:date].any? %>
      <p class="mt-1 text-xs text-red-600"><%= mail.errors[:date].first %></p>
    <% end %>
  </div>

  <div>
    <%= f.label :provider, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :provider, [["Gmail", "gmail"], ["Yahoo", "yahoo"]],
          { include_blank: "— select —" },
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 #{"border-red-400" if mail.errors[:provider].any?}" %>
    <% if mail.errors[:provider].any? %>
      <p class="mt-1 text-xs text-red-600"><%= mail.errors[:provider].first %></p>
    <% end %>
  </div>

  <div>
    <%= f.label :email_id, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :email_id, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500 #{"border-red-400" if mail.errors[:email_id].any?}" %>
    <% if mail.errors[:email_id].any? %>
      <p class="mt-1 text-xs text-red-600"><%= mail.errors[:email_id].first %></p>
    <% end %>
  </div>

  <div>
    <%= f.label :company, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :company, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :job_title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :job_title, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :action, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :action, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "px-5 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", application_mails_path, class: "px-5 py-2 text-sm text-gray-600 hover:text-gray-800" %>
  </div>
<% end %>
