<% content_for :title, "Application Emails" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Application Emails</h1>
  <%= link_to "New Email Record", new_application_mail_path,
        class: "px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors" %>
</div>

<% if notice.present? %>
  <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 text-green-800 rounded-lg text-sm"><%= notice %></div>
<% end %>

<% if alert.present? %>
  <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-800 rounded-lg text-sm"><%= alert %></div>
<% end %>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="px-4 py-3 text-left font-medium text-gray-600">Date</th>
        <th class="px-4 py-3 text-left font-medium text-gray-600">Provider</th>
        <th class="px-4 py-3 text-left font-medium text-gray-600">Company</th>
        <th class="px-4 py-3 text-left font-medium text-gray-600">Job Title</th>
        <th class="px-4 py-3 text-left font-medium text-gray-600">Action</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if @mails.empty? %>
        <tr>
          <td colspan="6" class="px-4 py-10 text-center text-gray-400">No emails found.</td>
        </tr>
      <% else %>
        <% @mails.each do |mail| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-3 text-gray-500 tabular-nums"><%= mail.date %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= mail.provider == 'gmail' ? 'bg-red-50 text-red-700' : 'bg-purple-50 text-purple-700' %>">
                <%= mail.provider %>
              </span>
            </td>
            <td class="px-4 py-3 font-medium text-gray-900"><%= mail.company || "—" %></td>
            <td class="px-4 py-3 text-gray-600"><%= mail.job_title || "—" %></td>
            <td class="px-4 py-3 text-gray-500"><%= mail.action || "—" %></td>
            <td class="px-4 py-3 text-right flex items-center justify-end gap-3">
              <%= link_to "View", application_mail_path(mail), class: "text-gray-500 hover:text-gray-700 font-medium" %>
              <%= link_to "Edit", edit_application_mail_path(mail), class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
              <%= button_to "Delete", application_mail_path(mail), method: :delete,
                    form: { data: { turbo_confirm: "Delete this email record?" } },
                    class: "text-red-500 hover:text-red-700 font-medium bg-transparent border-0 cursor-pointer p-0" %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>

<%== @pagy.series_nav %>
