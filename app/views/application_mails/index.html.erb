<%= render UI::PageHeaderComponent.new(title: "Application Emails", notice: notice, alert: alert) %>

<%= render ApplicationMails::SearchFormComponent.new(
      url: application_mails_path,
      query: @query,
      clear_url: application_mails_path
    ) %>

<div data-controller="batch">
  <%= render UI::TableComponent.new(
        collection: @mails,
        selectable: true,
        pagy: @pagy,
        filters: @filters
      ) do |table| %>
    <% table.with_batch_actions(
         [
           { label: "Fill gaps",  url: batch_application_mails_path, action: "fill",      variant: :neutral },
           { label: "Normalize",  url: batch_application_mails_path, action: "normalize", variant: :secondary },
           { label: "Reconcile",  url: batch_application_mails_path, action: "reconcile", variant: :primary,
             confirm: "Transfer selected emails into interviews?" },
           { label: "Delete",     url: batch_application_mails_path, action: "delete",    variant: :danger,
             confirm: "Delete selected emails?" }
         ]
       ) %>
    <% table.with_columns([
      { key: "date",      label: "Date" },
      { key: "provider",  label: "Provider", badge: ApplicationMails::ProviderBadgeComponent },
      { key: "company",   label: "Company" },
      { key: "job_title", label: "Job Title" },
      { key: "action",    label: "Action" }
    ]) %>
    <% table.with_action_column(
      actions: ->(mail) {
        [
          { label: "View", url: application_mail_path(mail), variant: :neutral },
          { label: "Edit", url: edit_application_mail_path(mail), variant: :primary },
          { label: "Delete", url: application_mail_path(mail), method: :delete, variant: :danger, confirm: "Delete this email record?" }
        ]
      }
    ) %>
  <% end %>
</div>
