<%= render UI::PageHeaderComponent.new(
  title: "#{@mail.company} — #{@mail.job_title}",
  parent: { label: "Application Emails", url: application_mails_path },
  notice: notice
) do |header| %>
  <% header.with_action(type: :link,   label: "Edit",   url: edit_application_mail_path(@mail)) %>
  <% header.with_action(type: :delete, label: "Delete", url: application_mail_path(@mail), confirm: "Delete this email record?") %>
<% end %>

<%= render UI::DetailCardComponent.new(
      entity: @mail,
      attributes: [
        { label: "Date",      attribute: :date,     type: :date },
        { label: "Provider",  attribute: :provider, type: :badge,
          variant_map: { "gmail" => :danger, "yahoo" => :info } },
        { label: "Email ID",  attribute: :email_id, type: :mono },
        { label: "Company",   attribute: :company },
        { label: "Job Title", attribute: :job_title },
        { label: "Action",    attribute: :action }
      ]
    ) %>
