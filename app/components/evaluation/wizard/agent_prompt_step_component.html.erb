<%= form_with url: wizard_step_evaluation_experiments_path, method: :post, class: "space-y-6" do |f| %>
  <%= f.hidden_field :current_step, value: 1 %>

  <div>
    <label for="wizard_agent_name" class="block text-sm font-medium text-gray-700 mb-1">Agent</label>
    <%= select_tag "wizard[agent_name]",
          options_for_select(@agent_names.map { |n| [n, n] }, @agent_name),
          id: "wizard_agent_name",
          prompt: "— select agent —",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500",
          data: {
            controller: "agent-select",
            action: "change->agent-select#loadVersions",
            "agent-select-versions-url-value": prompt_versions_evaluation_experiments_path
          } %>
  </div>

  <div>
    <label for="wizard_prompt_id" class="block text-sm font-medium text-gray-700 mb-1">Prompt version</label>
    <%= select_tag "wizard[prompt_id]",
          options_for_select(prompt_options, @prompt_id&.to_i),
          id: "wizard_prompt_id",
          include_blank: "— latest —",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500" %>
  </div>

  <div>
    <label for="wizard_experiment_name" class="block text-sm font-medium text-gray-700 mb-1">Experiment name</label>
    <%= text_field_tag "wizard[experiment_name]", @experiment_name,
          id: "wizard_experiment_name",
          placeholder: "e.g. Classify v2 — May 2026",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500" %>
  </div>

  <div>
    <label for="wizard_sample_model" class="block text-sm font-medium text-gray-700 mb-1">Sample model</label>
    <%= select_tag "wizard[sample_model]",
          options_for_select(model_options, @sample_model),
          id: "wizard_sample_model",
          include_blank: "Use default (env var)",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500" %>
  </div>

  <div>
    <label for="wizard_evaluation_model" class="block text-sm font-medium text-gray-700 mb-1">Evaluation model</label>
    <%= select_tag "wizard[evaluation_model]",
          options_for_select(model_options, @evaluation_model),
          id: "wizard_evaluation_model",
          include_blank: "Use default (env var)",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500" %>
  </div>

  <div class="flex justify-end">
    <button type="submit" class="px-5 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700">
      Next →
    </button>
  </div>
<% end %>
