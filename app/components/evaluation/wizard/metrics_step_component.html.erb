<div class="space-y-6">
  <%# Existing metrics list %>
  <div>
    <h3 class="text-sm font-semibold text-gray-700 mb-3">Metrics for <%= @agent_name %></h3>
    <div id="<%= metrics_list_id %>" class="space-y-2">
      <% if empty? %>
        <p class="text-sm text-gray-400">No metrics yet — add one below or generate with AI.</p>
      <% else %>
        <% @metrics.each do |metric| %>
          <div id="<%= dom_id(metric) %>" class="flex items-center justify-between p-3 border border-gray-200 rounded-lg bg-white">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate"><%= metric.name %></p>
              <p class="text-xs text-gray-500 truncate"><%= metric.description %></p>
            </div>
            <div class="flex items-center gap-4 ml-4 shrink-0">
              <span class="text-xs text-gray-400">weight: <%= metric.weight %></span>
              <%= button_to "×", evaluation_metric_path(metric), method: :delete,
                    class: "text-gray-400 hover:text-red-500 font-bold text-base leading-none",
                    data: { turbo_method: :delete } %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# AI generation section %>
  <turbo-frame id="metric-suggestions">
    <%= form_with url: generate_evaluation_metrics_path, method: :post, class: "flex items-center gap-3" do |f| %>
      <%= f.hidden_field :agent_name, value: @agent_name %>
      <button type="submit" class="text-sm text-indigo-600 hover:text-indigo-800 font-medium">
        ✦ Generate metrics with AI
      </button>
    <% end %>
  </turbo-frame>

  <%# Inline add form %>
  <div id="metric-form" data-controller="disclosure">
    <button type="button" data-action="disclosure#toggle" class="text-sm text-gray-600 hover:text-gray-900 font-medium">
      + Add metric manually
    </button>
    <div data-disclosure-target="content" class="mt-3 hidden">
      <%= form_with url: evaluation_metrics_path, method: :post, data: { turbo: true } do |f| %>
        <%= f.hidden_field :evaluation_metric, name: "evaluation_metric[agent_name]", value: @agent_name %>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Name</label>
            <%= text_field_tag "evaluation_metric[name]", nil, class: "w-full rounded border border-gray-300 px-2 py-1.5 text-sm" %>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Weight</label>
            <%= number_field_tag "evaluation_metric[weight]", 1.0, step: 0.1, min: 0, class: "w-full rounded border border-gray-300 px-2 py-1.5 text-sm" %>
          </div>
          <div class="col-span-2">
            <label class="block text-xs font-medium text-gray-600 mb-1">Description</label>
            <%= text_area_tag "evaluation_metric[description]", nil, rows: 2, class: "w-full rounded border border-gray-300 px-2 py-1.5 text-sm" %>
          </div>
        </div>
        <div class="mt-2 flex gap-2">
          <button type="submit" class="px-3 py-1.5 text-xs font-medium text-white bg-indigo-600 rounded hover:bg-indigo-700">Save metric</button>
          <button type="button" data-action="disclosure#toggle" class="px-3 py-1.5 text-xs font-medium text-gray-600 border border-gray-300 rounded hover:bg-gray-50">Cancel</button>
        </div>
      <% end %>
    </div>
  </div>

  <%# Advance wizard %>
  <%= form_with url: wizard_step_evaluation_experiments_path, method: :post do |f| %>
    <%= f.hidden_field :current_step, value: 2 %>
    <div class="flex justify-end pt-2 border-t border-gray-100">
      <button type="submit" class="px-5 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700">
        Next →
      </button>
    </div>
  <% end %>
</div>
