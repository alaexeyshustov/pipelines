<% if @parent %>
  <% content_for :title, @parent[:label] %>

  <div class="mb-6 flex items-center gap-2 text-sm text-gray-500" data-testid="breadcrumb">
    <%= link_to @parent[:label], @parent[:url], class: "hover:text-gray-700" %>
    <span>›</span>
    <span class="text-gray-900"><%= @title %></span>
  </div>
<% else %>
  <% content_for :title, @title %>
<% end %>

<% if @notice.present? %>
  <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 text-green-800 rounded-lg text-sm" data-testid="notice"><%= @notice %></div>
<% end %>

<% if @alert.present? %>
  <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-800 rounded-lg text-sm" data-testid="alert"><%= @alert %></div>
<% end %>

<div class="mb-6 flex items-center <%= actions? ? 'justify-between' : '' %>" data-testid="page-header">
  <div class="flex items-center gap-3">
    <h1 class="text-2xl font-bold text-gray-900"><%= @title %></h1>
    <%= badge if badge? %>
  </div>
  <% if actions? %>
    <div class="flex items-center gap-3">
      <% actions.each do |action| %>
        <%= action %>
      <% end %>
    </div>
  <% end %>
</div>

