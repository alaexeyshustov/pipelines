<div data-controller="<%= controller_value %>">
  <div class="border-b border-gray-200 mb-6">
    <nav class="-mb-px flex gap-6" aria-label="Tabs" role="tablist">
      <% tabs.each do |tab| %>
        <%= tab %>
      <% end %>
    </nav>
  </div>
  <% panels.each do |panel| %>
    <%= panel %>
  <% end %>
</div>
