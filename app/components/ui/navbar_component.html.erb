<nav class="bg-white border-b border-gray-200 px-6 py-3 flex items-center gap-4" data-testid="navbar">
  <%= link_to helpers.root_path, class: "flex items-center gap-2 hover:opacity-80 transition-opacity", "data-testid": "navbar-brand" do %>
    <%= image_tag "/logo.svg", alt: "", height: 26, class: "block shrink-0" %>
    <span class="font-semibold text-gray-800 text-sm">Application Pipeline</span>
  <% end %>

  <% nav_items.each do |item| %>
    <%= link_to item.label, item.path,
          class: "text-sm #{active?(item.path) ? 'text-gray-900 font-medium' : 'text-gray-500 hover:text-gray-700'}",
          "data-testid": "navbar-item" %>
  <% end %>
</nav>

