#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require_relative "../config/environment"

require "dry/cli"
require "dotenv/load"

module PipelineCLI
  module Commands
    extend Dry::CLI::Registry

    class Run < Dry::CLI::Command
      WATCH_INTERVAL = 6 * 60 * 60 # 6 hours

      desc "Run a pipeline"

      option :pipeline,  required: true, desc: "The pipeline to run", default: "test"

      option :model,     default: ENV.fetch("DEFAULT_MODEL", "mistral-large-latest"),
                         desc: "LLM model (e.g. mistral-large-latest, gpt-5.1)"
      option :watch,     type: :boolean, default: false,
                         desc: "Run in a loop every 6 hours"
      option :log_level, default: "info",
                         desc: "Logging verbosity: debug, info, warn, error"
      option :log_file,  desc: "Path to log file (default: log/pipeline.log)"
      option :date,      desc: "Date for the workflow (default: today)"

      def call(pipeline:, model:, watch:, log_level: "info", log_file: nil, date: Date.today, **)
        pipeline_class = case pipeline.downcase
                         when "jobs"
                           Pipeline::JobsWorkflow
                         when 'test'
                           Pipeline::TestWorkflow
                         else
                           raise ArgumentError, "Unknown pipeline: #{pipeline}"
                         end

        log_path = log_file || Rails.root.join("log/pipeline.log").to_s
        FileUtils.mkdir_p(File.dirname(log_path))
        logger = Pipeline::Logger.new(level: log_level.to_sym, log_file: log_path)

        RubyLLM.configure do |config|
          config.mistral_api_key   = ENV.fetch("MISTRAL_API_KEY", "")
          config.openai_api_key    = ENV.fetch("OPENAI_API_KEY", "")
          config.gemini_api_key    = ENV.fetch("GEMINI_API_KEY", "")
          config.anthropic_api_key = ENV.fetch("ANTHROPIC_API_KEY", "")
          config.log_level = log_level.to_sym
          config.logger    = logger
        end

        providers = ENV.fetch("MAIL_PROVIDERS", "gmail,yahoo").split(",").map(&:strip).reject(&:empty?)
        Emails.configure(**providers.to_h { |p| [ p.to_sym, {} ] })

        loop do
          logger.info "Starting pipeline (model: #{model})..."
          result = pipeline_class.new(model: model, logger: logger, date: date).run
          logger.info "Pipeline complete: #{result.inspect}"

          break unless watch

          next_run = Time.now + WATCH_INTERVAL
          logger.info "Watch mode: next run at #{next_run.strftime('%Y-%m-%d %H:%M:%S')}. Ctrl+C to stop."
          sleep WATCH_INTERVAL
        end
      end
    end

    class TestProviders < Dry::CLI::Command
      desc "Test connectivity to configured mail providers"

      option :providers, default: ENV.fetch("MAIL_PROVIDERS", "gmail,yahoo").split(","),
                          desc: "Comma-separated list of providers to test (e.g. gmail,yahoo)"

      def call(providers: [], **)
        providers = providers.map(&:strip).reject(&:empty?)

        providers.each do |provider|
          adapter_class = Emails::PROVIDERS.fetch(provider) do
            puts "ERROR: Unknown provider '#{provider}'. Available: #{Emails::PROVIDERS.keys.join(', ')}"
            exit 1
          end
          adapter_class.test_connection
        rescue Google::Apis::AuthorizationError => e
          puts "ERROR: Authorization failed for #{provider} - #{e.message}"
          puts "  Try deleting the token file and re-running the test."
          exit 1
        rescue StandardError => e
          puts "ERROR: Failed to connect to #{provider} - #{e.message}"
          exit 1
        end
      end
    end

    class SetupProviders < Dry::CLI::Command
      desc "Guide to setting up mail providers"

      option :providers, default: ENV.fetch("MAIL_PROVIDERS", "gmail,yahoo").split(","),
                          desc: "Comma-separated list of providers to set up (e.g. gmail,yahoo)"

      def call(providers: [], **)
        providers = providers.map(&:strip).reject(&:empty?)

        providers.each do |provider|
          case provider.downcase
          when "gmail"
            Emails::Adapters::GmailAdapter.reset
            Emails::Adapters::GmailAdapter.setup
          when "yahoo"
            Emails::Adapters::YahooAdapter.setup
          else
            puts "No setup instructions for '#{provider}'. Please refer to provider documentation."
          end
          puts
        end
      end
    end

    class UploadGist < Dry::CLI::Command
      desc "Upload interviews data to a GitHub Gist as CSV"

      option :token,    desc: "GitHub personal access token (default: $GITHUB_TOKEN)"
      option :gist_id,  desc: "Existing Gist ID to update (default: $GIST_ID)"
      option :filename, default: "interviews.csv", desc: "Filename inside the Gist"

      def call(token: nil, gist_id: nil, filename: "interviews.csv", **)
        resolved_token = token || ENV["GITHUB_TOKEN"]
        unless resolved_token
          puts "ERROR: GitHub token required. Pass --token or set $GITHUB_TOKEN."
          exit 1
        end

        rows    = Interview.as_rows
        headers = Interview::COLUMN_NAMES
        csv     = CSV.generate(headers: true) do |c|
          c << headers
          rows.each { |r| c << headers.map { |h| r[h] } }
        end

        uploader = GistUploader.new(
          token:    resolved_token,
          gist_id:  gist_id || ENV["GIST_ID"],
          filename: filename
        )
        url = uploader.upload(csv)
        puts "Uploaded: #{url}"
      rescue GistUploader::ApiError => e
        puts "Upload failed: #{e.message}"
        exit 1
      end
    end

    register "run",            Run
    register "test",           TestProviders
    register "setup",          SetupProviders
    register "upload_gist",    UploadGist
  end
end

Dry::CLI.new(PipelineCLI::Commands).call
