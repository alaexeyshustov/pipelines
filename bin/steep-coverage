#!/usr/bin/env ruby
# frozen_string_literal: true

# Computes combined type coverage from `steep stats` and enforces a minimum threshold.
# Usage: bin/steep-coverage [--list] [threshold]
# Default threshold: 99.0
#   --list Print files below the threshold sorted by coverage ascending.

list_mode = ARGV.delete("--list")
threshold = (ARGV[0] || 99.0).to_f

stats = `bundle exec steep stats --log-level=fatal 2>/dev/null`

if stats.empty?
  warn "steep stats produced no output"
  exit 1
end

total_typed    = 0
total_all      = 0
under_threshold = []

stats.each_line do |line|
  parts = line.chomp.split(",")
  next unless parts.size == 7 && parts[2] == "success"

  total_typed += parts[3].to_i
  total_all   += parts[5].to_i

  next unless list_mode

  pct = parts[6].to_f
  under_threshold << [ parts[1], pct ] if pct < threshold
end

if total_all.zero?
  warn "No typed call sites found in steep stats output"
  exit 1
end

coverage = (total_typed.to_f / total_all * 100).round(2)
puts "Type coverage: #{coverage}% (#{total_typed}/#{total_all} calls typed)"

if list_mode
  if under_threshold.empty?
    puts "All files meet the #{threshold}% threshold."
  else
    puts "\nFiles below #{threshold}% (ascending):"
    under_threshold.sort_by { |_, pct| pct }.each do |file, pct|
      puts "  #{pct}%\t#{file}"
    end
  end
end

if coverage < threshold
  warn "Coverage #{coverage}% is below the required #{threshold}%"
  exit 1
end

puts "OK: coverage meets the #{threshold}% threshold"
