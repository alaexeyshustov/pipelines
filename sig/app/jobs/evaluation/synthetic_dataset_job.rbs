module Evaluation
  class SyntheticDatasetJob < ApplicationJob
    SYSTEM_PROMPT: String
    DEFAULT_MODEL: String

    def perform: (draft_token: String, agent_name: String, dataset_name: String, count: Integer, ?hints: String) -> void

    private

    def fetch_system_prompt: (String) -> String
    def fetch_few_shot_samples: (String) -> Array[untyped]
    def build_user_message: (system_prompt_text: String, count: Integer, hints: String, few_shot: Array[untyped]) -> String
    def call_llm: (String, String) -> Array[untyped]
    def create_dataset_with_records: (String, String, Array[untyped]) -> Leva::Dataset
    def update_draft: (String, status: String, ?dataset_id: Integer?, ?error_message: String?) -> void
  end
end
