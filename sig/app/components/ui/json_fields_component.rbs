module UI
  class JsonFieldsComponent < ViewComponent::Base
    INPUT_CLASSES: String
    CHECKBOX_CLASSES: String
    LABEL_CLASSES: String

    @form: ActionView::Helpers::FormBuilder
    @schema: json_object
    @name_prefix: String?

    def initialize: (
      form: ActionView::Helpers::FormBuilder,
      schema: json_object,
      ?name_prefix: String?
    ) -> void

    def fields: () -> Array[{ name: String, schema: json_object, kind: Symbol, required: bool }]
    def hardcoded_display: (json_object field_schema) -> String
    def input_name: (String field_name, ?array: bool) -> String

    private

    def properties: () -> json_object
    def required_fields: () -> Array[String]
    def field_kind: (json_object schema) -> Symbol
    def array_with_checkboxes?: (json_object schema) -> bool
    def string_with_enum?: (json_object schema) -> bool
    def numeric_type?: (json_object schema) -> bool
  end
end
