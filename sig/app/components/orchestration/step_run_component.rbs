module Orchestration
  class StepRunComponent < ViewComponent::Base
    @step: Step
    @action_run_records: Array[ActionRun]
    @derived_status: String
    @available_outputs: Hash[String, json_object]?

    def initialize: (entry: { step: Step, action_runs: Array[ActionRun], derived_status: String }) -> void
    def before_render: () -> void
    def status_badge: () -> RunStatusBadgeComponent?
    def action_run_items: () -> Array[ActionRunComponent]
  end
end
