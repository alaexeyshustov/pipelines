module Evaluation
  module Wizard
    class ReviewStepComponent < ViewComponent::Base
      @form: Wizard::Step4Form

      def initialize: (form: Wizard::Step4Form) -> void

      def agent_name: () -> String?
      def prompt: () -> Evaluation::Prompt?
      def experiment_name: () -> String?
      def metrics_count: () -> Integer
      def dataset: () -> Evaluation::Dataset?
      def no_metrics?: () -> bool
      def prompt_label: () -> String
      def dataset_label: () -> String
    end
  end
end
