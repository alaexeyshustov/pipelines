module Evaluation
  module Wizard
    class DatasetStepComponent < ViewComponent::Base
      @form: Wizard::Step3Form

      def initialize: (form: Wizard::Step3Form) -> void

      def agent_name: () -> String?
      def datasets: () -> Dataset::relation
      def draft_token: () -> String?
      def selected_dataset_id: () -> String?
      def dataset_selected?: (Dataset dataset) -> bool
      def record_count: (Dataset dataset) -> Integer
    end
  end
end
