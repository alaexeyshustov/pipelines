module Evaluation
  class DashboardComponent < ViewComponent::Base
    @summary: Evaluation::AgentSummaryQuery::AgentSummary

    def initialize: (summary: Evaluation::AgentSummaryQuery::AgentSummary) -> void
    def agent_name: () -> String
    def latest_experiment: () -> Evaluation::Experiment?
    def latest_score: () -> Float?
    def active_prompt_version: () -> Integer?
    def sample_count: () -> Integer
    def score_over_time_data: () -> Array[{ created_at: String, avg_score: Float? }]
    def format_score: (Float? score) -> String
  end
end
