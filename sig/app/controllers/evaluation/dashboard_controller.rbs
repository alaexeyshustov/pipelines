module Evaluation
  class DashboardController < ApplicationController
    AgentSummary: Data

    @experiments: Array[Evaluation::Experiment]

    def show: () -> void

    private

    def agent_summaries: () -> Array[Evaluation::AgentSummaryQuery::AgentSummary]
    def batch_stats: (Array[Integer] experiment_ids) -> Hash[Integer, { avg: Float?, count: Integer }]
    def build_score_history: (Array[Evaluation::Experiment] experiments, Hash[Integer, { avg: Float?, count: Integer }] avgs_by_id) -> Array[Hash[Symbol, String | Float | nil]]
    def active_versions_for: (Array[String] agent_names) -> Hash[String, Integer]
  end
end
