module Evaluation
  class PromptsController < ApplicationController
    @prompts: Prompt::relation

    def index: () -> void
    def compare: () -> void

    private

    def find_compare_prompts: () -> [ Evaluation::Prompt?, Evaluation::Prompt? ]
