module Evaluation
  class ExperimentsController < ApplicationController
    include Evaluation::ExperimentWizard

    @experiments: Experiment::relation
    @experiment: Experiment
    @candidate: Experiment?
    @result: Comparison::ComparisonResult?
    @metric_name: String?
    @justifications: Justification::relation
    @wizard_form: WizardForm

    def index: () -> void
    def show: () -> void
    def new: () -> void
    def create: () -> void
    def destroy: () -> void
    def snapshot_agent_prompt: () -> void
    def prompt_content: () -> void
    def fork_prompt: () -> void
    def prompt_versions: () -> void
    def status_frame: () -> void
    def metric_results: () -> void
    def improve: () -> void
    def compare: () -> void
    def activate: () -> void

    private

    def set_experiment: () -> void
    def redirect_after_improve_failure: (String context, StandardError e) -> void
  end
end
