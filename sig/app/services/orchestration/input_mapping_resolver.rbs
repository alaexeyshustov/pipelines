module Orchestration
  class InputMappingResolver
    class UnknownOutputKey < StandardError
    end

    class MissingPath < StandardError
    end

    @input_mapping: json_object
    @previous_outputs: Hash[String, json_object]

    def initialize: (input_mapping: json_object, previous_outputs: Hash[String, json_object]) -> void
    def resolve: () -> json_object

    private

    def fetch_upstream!: (String from, ?optional: bool) -> json_object?
    def dig_path: (json_object_value upstream, String path, String from, bool? optional) -> json_object_value
  end
end
