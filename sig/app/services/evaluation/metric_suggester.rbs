module Evaluation
  class MetricSuggester
    SYSTEM_PROMPT: String
    DEFAULT_MODEL: String

    class Error < StandardError
    end

    def self.call: (agent_name: String, model: String?) -> Array[{ name: String, description: String, weight: Float }]

    @agent_name: String
    @model: String?

    def initialize: (agent_name: String, model: String?) -> void
    def call: () -> Array[{ name: String, description: String, weight: Float }]

    private

    def query_llm: (String prompt) -> RubyLLM::Message
    def agent_system_prompt: () -> String?
    def parse_response: (json_object_value) -> Array[{ name: String, description: String, weight: Float }]
    def parse_metric_entry: (json_object_value entry) -> { name: String, description: String, weight: Float }?
    def extract_metric_fields: (json_object entry) -> [ String, String, Float ]
    def out_of_range_weight?: (Float weight) -> bool
  end
end
