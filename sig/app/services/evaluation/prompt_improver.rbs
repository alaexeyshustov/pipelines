module Evaluation
  class PromptImprover
    class Error < StandardError
    end

    def self.call: (experiment: Evaluation::Experiment, ?model: String) -> Evaluation::Prompt

    def initialize: (experiment: Evaluation::Experiment, model: String) -> void

    def call: () -> Evaluation::Prompt

    private

    def evaluation_data: () -> ActiveRecord::Relation
    def metrics: () -> ActiveRecord::Relation
    def build_improvement_message: (current_prompt: Evaluation::Prompt, evaluation_data: ActiveRecord::Relation, metrics: ActiveRecord::Relation) -> String
    def run_agent: (String input) -> Hash[Symbol, String]
    def parse_response: (String | Hash[untyped, untyped] content) -> Hash[Symbol, String]
  end
end
