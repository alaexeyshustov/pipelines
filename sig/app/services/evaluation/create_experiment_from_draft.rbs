module Evaluation
  class NoMetricsError < StandardError
  end

  class CreateExperimentFromDraft
    include SteepHacks

    def self.call: (draft: WizardDraft) -> Experiment

    @agent_name: String?
    @prompt_id: Integer?

    def initialize: (draft: WizardDraft) -> void

    def call: () -> Experiment

    private

    attr_reader draft: WizardDraft

    def payload: () -> json_object
    def resolve_prompt: () -> void
    def no_active_metrics?: () -> bool
    def create_experiment!: () -> Experiment
  end
end
