module Interviews
  class BatchService
    STATUS_PRIORITY: Array[String]

    class Result
      attr_reader ok: bool
      attr_reader message: String?
      attr_reader csv: String?

      def initialize: (ok: bool, ?message: String?, ?csv: String?) -> void
      def ok?: () -> bool
      def csv?: () -> bool
    end

    @ids: Array[String] | Array[Integer]
    @batch_action: String

    def self.call: (ids: Array[String] | Array[Integer], batch_action: String) -> Result

    def initialize: (ids: Array[String] | Array[Integer], batch_action: String) -> void
    def call: () -> Result

    private

    def ids_needed?: () -> bool
    def perform_batch_action: (Integer count) -> Result
    def delete_interviews: (Integer count) -> Result
    def export_interviews: () -> Result
    def handle_merge: (Integer count) -> Result

    def merge_records: () -> void
    def build_merge_attributes: (Interview::relation records) -> { status: String?, first_interview_at: String?, second_interview_at: String?, third_interview_at: String?, fourth_interview_at: String? }
    def collect_dates: (Interview::relation records) -> Array[String]
  end
end
