module Interviews
  class GistExportService
    GITHUB_API_URI: String

    class Result
      attr_reader ok: bool
      attr_reader message: String

      def initialize: (ok: bool, message: String) -> void
      def ok?: () -> bool
    end

    @ids: Array[String] | Array[Integer] | nil
    @gist_id: String

    def self.call: (ids: Array[String] | Array[Integer] | nil, gist_id: String) -> Result

    def initialize: (ids: Array[String] | Array[Integer] | nil, gist_id: String) -> void
    def call: () -> Result

    private

    def build_error_result: (Net::HTTPResponse response) -> Result
    def parse_error_body: (String body) -> json_object?
    def patch_gist: (String token, String csv_content) -> Net::HTTPResponse
  end
end
