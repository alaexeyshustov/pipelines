module Emails
  class ListTool < RubyLLM::Tool
    def self.readonly?: () -> bool
    def name: () -> String
    def execute: (
      provider: String,
      ?max_results: Integer,
      ?after_date: String?,
      ?before_date: String?,
      ?offset: Integer,
      ?label: String?
    ) -> untyped
  end
end
