module Records
  class InsertRowsTool < RubyLLM::Tool
    def name: () -> String
    def execute: (table: String, data: String) -> { status: String, rows_added: Integer, ids: Array[Integer], duplicate: Array[{ existing_id: Integer? }], invalid: Array[String] }

    private

    def find_duplicate_id: (untyped model, Hash[String, untyped] attrs) -> Integer?
    def safe_parse_data: (String data) -> { status: String, records: Array[untyped] }
  end
end
