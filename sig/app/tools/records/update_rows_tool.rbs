module Records
  class UpdateRowsTool < RubyLLM::Tool
    include ModelResolver

    def self.readonly?: () -> bool
    def name: () -> String
    def execute: (table: String, id: String, data: String) -> { ?error: String, status: String }

    private

    def apply_update: (ApplicationRecord record, _HasColumnNames model, String data) -> { ?error: String, status: String }
  end
end
