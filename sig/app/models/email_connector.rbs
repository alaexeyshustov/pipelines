class EmailConnector < ApplicationRecord
  type relation = _Relation[EmailConnector, Integer]

  def self.all: () -> relation
  def self.find: (Integer id) -> EmailConnector

  attr_accessor name: String
  attr_accessor provider: String
  attr_accessor configuration: Hash[String, json_object_value]
  attr_accessor enabled: bool
  attr_accessor last_connected_at: Time?
  attr_accessor status: String?

  def test_connection: () -> { success: bool, error: String? }

  private

  def resolve_adapter_class: () -> (singleton(Emails::Adapters::GmailAdapter) | singleton(Emails::Adapters::YahooAdapter) | nil)
  def probe_connection: ((singleton(Emails::Adapters::GmailAdapter) | singleton(Emails::Adapters::YahooAdapter)) adapter_class) -> { success: bool, ?error: String }
  def run_provider_check: ((singleton(Emails::Adapters::GmailAdapter) | singleton(Emails::Adapters::YahooAdapter)) adapter_class) -> void
  def connect_gmail_adapter: (singleton(Emails::Adapters::GmailAdapter) adapter_class) -> void
  def connect_yahoo_adapter: (singleton(Emails::Adapters::YahooAdapter) adapter_class) -> void
  def convert_configuration_to_hash: () -> void
end
