class EmailConnector < ApplicationRecord
  def self.all: () -> ActiveRecord::Relation
  def self.find: (Integer id) -> EmailConnector

  attr_accessor name: String
  attr_accessor provider: String
  attr_accessor configuration: Hash[Symbol | String, untyped]
  attr_accessor enabled: bool
  attr_accessor last_connected_at: Time?
  attr_accessor status: String?

  def test_connection: () -> { success: bool, error: String? }

  private

  def convert_configuration_to_hash: () -> void
end
