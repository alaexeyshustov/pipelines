class ApplicationMail < ApplicationRecord
  COLUMN_NAMES: Array[String]

  include Searchable

  type relation = _Relation[ApplicationMail, Integer]

  def self.tool_column_names: () -> Array[String]
  def self.search: (String? q) -> relation
  def self.groupped: () -> relation

  def date: () -> String?
  def date=: (String?) -> String?
  def provider: () -> String?
  def provider=: (String?) -> String?
  def email_id: () -> String?
  def email_id=: (String?) -> String?
  def company: () -> String?
  def company=: (String?) -> String?
  def job_title: () -> String?
  def job_title=: (String?) -> String?
  def action: () -> String?
  def action=: (String?) -> String?

  def self.as_rows: (?ActiveRecord::Relation scope) -> Array[Hash[String, String?]]
end
