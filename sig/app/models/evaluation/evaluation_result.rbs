module Evaluation
  class EvaluationResult < ApplicationRecord
    type relation = _Relation[EvaluationResult, Integer]

    def self.table_name: () -> String
    def self.create!: (**top attrs) -> EvaluationResult
    def self.where: (**top attrs) -> relation
    def self.joins: (*top) -> relation
    def self.group: (*top) -> relation
    def self.average: (Symbol column) -> Float?
    def self.pluck: (*(String | Symbol)) -> Array[json_object_value]
    def self.per_metric_averages: (Experiment experiment) -> Hash[String, Float]

    def score: () -> Float?
    def score=: (Float | Integer | nil) -> (Float | Integer | nil)
    def evaluator_class: () -> String?
    def evaluator_class=: (String?) -> String?

    def experiment: () -> Experiment?
    def experiment=: (Experiment?) -> Experiment?
    def dataset_sample: () -> DatasetSample?
    def dataset_sample=: (DatasetSample?) -> DatasetSample?
    def sample: () -> Sample?
    def sample=: (Sample?) -> Sample?

    def justifications: () -> Justification::relation
  end
end
