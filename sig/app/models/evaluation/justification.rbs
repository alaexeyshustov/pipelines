module Evaluation
  class Justification < ApplicationRecord
    type relation = _Relation[Justification, Integer]

    def self.joins: (*top) -> relation
    def self.includes: (*top) -> relation
    def self.eager_load: (*top) -> relation
    def self.where: (**top) -> relation

    def evaluation_result: () -> Evaluation::EvaluationResult
    def metric_name: () -> String
    def justification: () -> String
  end
end
