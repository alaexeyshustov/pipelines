module Evaluation
  class RunnerResult < ApplicationRecord
    def self.table_name: () -> String
    def self.create!: (**untyped attrs) -> RunnerResult
    def self.where: (**untyped attrs) -> ActiveRecord::Relation
    def self.includes: (*untyped) -> ActiveRecord::Relation
    def self.order: (*untyped) -> ActiveRecord::Relation

    def prediction: () -> String?
    def prediction=: (String?) -> String?
    def runner_class: () -> String?
    def runner_class=: (String?) -> String?
    def prompt_version: () -> Integer?

    def experiment: () -> Evaluation::Experiment?
    def experiment=: (Evaluation::Experiment?) -> Evaluation::Experiment?
    def dataset_record: () -> Evaluation::DatasetRecord
    def dataset_record=: (Evaluation::DatasetRecord) -> Evaluation::DatasetRecord
    def prompt: () -> Evaluation::Prompt
    def prompt=: (Evaluation::Prompt) -> Evaluation::Prompt

    def evaluation_results: () -> ActiveRecord::Associations::CollectionProxy

    def ground_truth: () -> untyped
  end
end
