module Evaluation
  class Experiment < ApplicationRecord
    def self.table_name: () -> String
    def self.find: (Integer id) -> Experiment
    def self.find_by: (**untyped attrs) -> Experiment?
    def self.create!: (**untyped attrs) -> Experiment
    def self.where: (**untyped attrs) -> ActiveRecord::Relation
    def self.joins: (*untyped) -> ActiveRecord::Relation
    def self.includes: (*untyped) -> ActiveRecord::Relation
    def self.order: (*untyped) -> ActiveRecord::Relation

    def id: () -> Integer
    def created_at: () -> Time
    def name: () -> String?
    def name=: (String?) -> String?
    def description: () -> String?
    def runner_class: () -> String?
    def runner_class=: (String?) -> String?
    def evaluator_classes: () -> Array[String]
    def evaluator_classes=: (Array[String]) -> Array[String]
    def metadata: () -> Hash[String, untyped]?
    def metadata=: (Hash[String, untyped]?) -> Hash[String, untyped]?
    def status: () -> String
    def status=: (String | Symbol) -> (String | Symbol)
    def sample_model: () -> String?
    def sample_model=: (String?) -> String?
    def evaluation_model: () -> String?
    def evaluation_model=: (String?) -> String?

    def dataset: () -> Evaluation::Dataset
    def dataset=: (Evaluation::Dataset) -> Evaluation::Dataset
    def prompt: () -> Evaluation::Prompt?
    def prompt=: (Evaluation::Prompt?) -> Evaluation::Prompt?

    def samples: () -> ActiveRecord::Associations::CollectionProxy
    def evaluation_results: () -> ActiveRecord::Associations::CollectionProxy

    def pending?: () -> bool
    def sampling?: () -> bool
    def evaluating?: () -> bool
    def completed?: () -> bool
    def failed?: () -> bool
    def in_progress?: () -> bool

    def update!: (**untyped attrs) -> Experiment

    def agent_name: () -> String?
    def runner_model: () -> String?
    def newer_experiment: () -> Experiment?
    def per_metric_averages: () -> Hash[String, Float]
  end
end
