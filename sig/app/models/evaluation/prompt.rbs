module Evaluation
  class Prompt < ApplicationRecord
    type relation = _Relation[Prompt, Integer]

    def self.last_for_agent: (String agent_name) -> Prompt?

    def self.table_name: () -> String
    def self.find: (Integer id) -> Prompt
    def self.find_by: (**top attrs) -> Prompt?
    def self.create!: (**top attrs) -> Prompt
    def self.where: (**top attrs) -> relation
    def self.order: (*top) -> relation
    def self.transaction: () { () -> void } -> void
    def self.distinct: () -> relation

    def id: () -> Integer
    def name: () -> String?
    def name=: (String?) -> String?
    def system_prompt: () -> String?
    def system_prompt=: (String?) -> String?
    def user_prompt: () -> String?
    def user_prompt=: (String?) -> String?
    def version: () -> Integer?
    def version=: (Integer?) -> Integer?
    def metadata: () -> String?
    def metadata=: (String?) -> String?
    def output_schema: () -> json_object?
    def output_schema=: (json_object?) -> json_object?

    def experiments: () -> Experiment::relation
    def samples: () -> Sample::relation

    def update!: (**top attrs) -> Prompt

    private

    def increment_version: () -> Integer
    def assign_next_version: () -> Integer
  end
end
