module Evaluation
  class Sample < ApplicationRecord
    type relation = _Relation[Sample, Integer]

    def self.table_name: () -> String
    def self.create!: (**top attrs) -> Sample
    def self.where: (**top attrs) -> relation
    def self.includes: (*top) -> relation
    def self.order: (*top) -> relation

    def tool_calls: () -> Array[json_object]?
    def tool_calls=: (Array[json_object]?) -> Array[json_object]?
    def output: () -> String?
    def output=: (String?) -> String?

    def experiment: () -> Experiment?
    def experiment=: (Experiment?) -> Experiment?
    def dataset_sample: () -> DatasetSample
    def dataset_sample=: (DatasetSample) -> DatasetSample
    def prompt: () -> Prompt
    def prompt=: (Prompt) -> Prompt
  end
end
