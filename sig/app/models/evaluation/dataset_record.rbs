module Evaluation
  class DatasetRecord < ApplicationRecord
    def self.table_name: () -> String
    def self.find: (Integer id) -> DatasetRecord
    def self.create!: (**untyped attrs) -> DatasetRecord

    def dataset: () -> Evaluation::Dataset
    def dataset=: (Evaluation::Dataset) -> Evaluation::Dataset
    def recordable: () -> untyped
    def recordable=: (untyped) -> untyped
    def recordable_type: () -> String
    def recordable_id: () -> Integer

    def runner_results: () -> ActiveRecord::Associations::CollectionProxy
    def evaluation_results: () -> ActiveRecord::Associations::CollectionProxy

    def ground_truth: () -> untyped
  end
end
