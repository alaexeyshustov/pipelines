module Orchestration
  module Executable
    def self.included: (top base) -> void

    module ClassMethods
      @_input_schema: json_object?
      @_input_schema_types: Hash[String, json_object]?

      def input_schema: (?Hash[Symbol, json_object] declared_types) -> json_object?

      private

      def build_input_schema!: () -> json_object
      def extract_keyword_names: (Array[[Symbol, Symbol]] params) -> Array[String]
      def validate_schema_consistency!: (Hash[String, json_object] declared, Array[String] keywords) -> void
    end
  end
end
