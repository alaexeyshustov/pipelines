module Emails
  module Adapters
    class GmailPaginator
      @max_results: Integer
      @offset: Integer
      @block: ^(Integer, String?) -> Google::Apis::GmailV1::ListMessagesResponse?

      def initialize: (Integer max_results, Integer offset) { (Integer page_size, String? page_token) -> Google::Apis::GmailV1::ListMessagesResponse? } -> void
