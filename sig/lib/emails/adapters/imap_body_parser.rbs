module Emails
  module Adapters
    class ImapBodyParser
      def self.decode_header: (String? value) -> String?

      @mail: Mail::Message

      def initialize: (Mail::Message mail) -> void
      def body: () -> String

      private

      def extract_body: (Mail::Message | Mail::Part mail) -> String
      def extract_multipart_body: (Mail::Message | Mail::Part mail) -> String
      def decode_part: ((Mail::Message | Mail::Part)? part) -> String
      def strip_html: (String html) -> String
    end
  end
end
