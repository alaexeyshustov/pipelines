module Emails
  class GmailAuth
    class InteractiveAuthorizationRequired < StandardError
    end

    USER_ID: String

    @credentials_path: String
    @token_path: String
    @scope: Array[String]
    @output: IO

    def initialize: (credentials_path: String, token_path: String, scope: Array[String], ?output: IO) -> void
    def credentials: () -> untyped
    def authorization_url: (callback_uri: String) -> String
    def exchange_code: (code: String, callback_uri: String) -> untyped

    private

    def build_authorizer: (callback_uri: String) -> untyped
    def interactive_authorization_allowed?: () -> bool
    def open_authorization_url: (String) -> bool
  end
end
