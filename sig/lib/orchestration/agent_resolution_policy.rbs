module Orchestration
  class AgentResolutionPolicy
    class Result
      attr_reader model: String?
      attr_reader prompt: String?
      attr_reader tools: Array[singleton(RubyLLM::Tool)]?
      attr_reader output_schema: json_object?

      def initialize: (
        model: String?,
        prompt: String?,
        tools: Array[singleton(RubyLLM::Tool)]?,
        output_schema: json_object?
      ) -> void
    end

    @action: Action
    @pipeline_model: String?
    @prompt_override: String?
    @tool_classes: Array[singleton(RubyLLM::Tool)]?

    def initialize: (
      action: Action,
      ?pipeline_model: String?,
      ?prompt_override: String?,
      ?tool_classes: Array[singleton(RubyLLM::Tool)]?
    ) -> void

    def resolve: () -> Result

    private

    def agent_record: () -> Agent
    def resolved_model: () -> String?
    def resolved_prompt: () -> String?
    def resolved_tools: () -> Array[singleton(RubyLLM::Tool)]?
    def resolve_tool_class: (String | singleton(RubyLLM::Tool) tool) -> singleton(RubyLLM::Tool)
    def resolved_output_schema: () -> json_object?
    def resolved_generation_schema: () -> json_object?
    def normalized_hash: (json_object | String | nil value, field_name: String) -> json_object
  end
end
