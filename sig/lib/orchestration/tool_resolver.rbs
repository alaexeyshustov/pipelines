module Orchestration
  class ToolResolver
    REGISTRY: Hash[String, singleton(RubyLLM::Tool)]

    @agent: Agent

    def initialize: (agent: Agent) -> void

    def resolve: () -> Array[singleton(RubyLLM::Tool)]

    private

    def resolve_configured: (Array[String] configured) -> Array[singleton(RubyLLM::Tool)]
    def resolve_class: (String tool) -> singleton(RubyLLM::Tool)
  end
end
