module Evaluation
  module Evaluators
    class LLMJudgeEval
      type metric_result = { metric_name: String, score: Float, justification: String }

      @judge_model: String

      def self.judge_model: () -> String
      def self.judge_model=: (String model) -> String

      def evaluate: (Sample sample, DatasetSample dataset_sample, agent_name: String?, ?model: String) -> Array[metric_result]
      def evaluate_and_store: (Experiment experiment, Sample sample) -> Array[EvaluationResult]

      private

      def fetch_instructions: (Sample sample) -> String?
      def fetch_output_schema: (Sample sample) -> untyped
      def call_judge: (user_input: String, ?model: String) -> Array[metric_result]
      def build_user_message: (sample: Sample, dataset_sample: DatasetSample, metrics: Array[Metric]) -> String
      def parse_judge_response: (untyped content) -> Array[metric_result]
      def normalize_entry: (untyped entry, Integer index) -> metric_result?
      def parse_output: (untyped output) -> untyped
    end
  end
end
