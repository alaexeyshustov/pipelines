module Evaluation
  class DatasetSeeder
    @agent_name: String
    @sample_size: Integer
    @dataset: Dataset

    class Result < Data
      attr_reader agent_name: String
      attr_reader created: Integer
      attr_reader skipped: Integer

      def self.new: (agent_name: String, created: Integer, skipped: Integer) -> Result
    end

    def self.call: (agent_name: String, ?sample_size: Integer) -> Result

    def initialize: (agent_name: String, ?sample_size: Integer) -> void
    def call: () -> Result

    private

    def candidate_runs: () -> Array[Orchestration::ActionRun]

    def dataset: () -> Dataset

    def sample_for: (Orchestration::ActionRun) -> DatasetSample
  end
end
