module Evaluation
  class DatasetSeeder
    @agent_name: String
    @sample_size: Integer
    @dataset: Dataset

    class Result < Data
      attr_reader agent_name: String
      attr_reader created: Integer
      attr_reader skipped: Integer

      def self.new: (agent_name: String, created: Integer, skipped: Integer) -> Result
    end

    def self.call: (agent_name: String, ?sample_size: Integer) -> Result

    def initialize: (agent_name: String, ?sample_size: Integer) -> void
    def call: () -> Result

    private

    def process_run: (Orchestration::AgentRunsQuery::Run run, Hash[Symbol, Integer] acc) -> void
    def candidate_runs: () -> Array[Orchestration::AgentRunsQuery::Run]
    def dataset: () -> Dataset
    def sample_for: (Orchestration::AgentRunsQuery::Run) -> DatasetSample
  end
end
